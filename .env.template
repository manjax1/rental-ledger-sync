# Plaid API Credentials
# Sign up at https://dashboard.plaid.com
PLAID_CLIENT_ID=your_plaid_client_id_here
PLAID_SECRET=your_plaid_secret_here
PLAID_ENV=production

# Plaid Access Token (auto-populated after first login via Plaid Link browser flow)
PLAID_ACCESS_TOKEN=

# Plaid Sandbox Test Settings (only used when PLAID_ENV=sandbox)
PLAID_TEST_INSTITUTION=ins_109508
PLAID_TEST_USERNAME=user_good
PLAID_TEST_PASSWORD=pass_good

# Email Notifications (Gmail)
# Use a Gmail App Password — not your regular password
# Generate one at: https://myaccount.google.com/apppasswords
EMAIL_SENDER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=your_16_char_app_password
EMAIL_RECIPIENT=your_email@gmail.com

# Ledger File Path
# Full path to your Excel workbook — must have a sheet named "Ledger"
LEDGER_FILE_PATH=/path/to/your/RentalPropertyLedger.xlsx
